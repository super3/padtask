# Anthropic API Key
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Server port (optional, defaults to 3000)
PORT=3000

# Allowed CORS origins (comma-separated, e.g. https://yourdomain.com,https://staging.yourdomain.com)
# If not set, only same-origin requests are allowed
ALLOWED_ORIGINS=

# API secret key for backend authentication (optional)
# When set, all API requests must include "Authorization: Bearer <key>" header
API_SECRET_KEY=
