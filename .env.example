# Anthropic API Key
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Server port (optional, defaults to 3000)
PORT=3000

# PostgreSQL connection string (optional — falls back to in-memory without it)
# Railway auto-injects this when you link a Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clerk backend secret key (optional — enables server-side user verification)
# Without it, all requests are treated as guest sessions.
# Get it from https://dashboard.clerk.com/ → API Keys → Secret keys
CLERK_SECRET_KEY=sk_test_...
