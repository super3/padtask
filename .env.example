# Anthropic API Key
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Server port (optional, defaults to 3000)
PORT=3000

# Umami analytics (optional) — enables /api/public-stats
# Get an API key from cloud.umami.is → Settings → API keys
UMAMI_API_KEY=
UMAMI_WEBSITE_ID=
# Override only if self-hosting Umami (default: https://api.umami.is/v1)
# UMAMI_API_URL=
